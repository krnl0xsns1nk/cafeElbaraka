<!DOCTYPE html>
<html lang="<%= restaurant.lang %>" dir="<%= restaurant.dir %>">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title><%= restaurant.seo.title %></title>
  <meta name="description" content="<%= restaurant.seo.description %>">
  <meta name="keywords" content="<%= restaurant.seo.keywords %>">

  <link rel="stylesheet" href="/css/style.css">
</head>

<body>

<header class="header">
  <div class="logo"><%= restaurant.name %></div>

  <nav>
    <a href="/">AR</a>
    <a href="/fr">FR</a>
    <a href="/en">EN</a>
  </nav>
</header>

<section class="hero">

  <div class="slides">
    <% restaurant.heroImages.forEach((img, i) => { %>
      <div class="slide <%= i === 0 ? 'active' : '' %>" style="background-image:url('<%= img %>')"></div>
    <% }) %>
  </div>

  <div class="hero-content">
    <h1><%= restaurant.hero.title %></h1>
    <p><%= restaurant.hero.subtitle %></p>
    <a href="#menu"><%= restaurant.hero.cta %></a>
  </div>

</section>

<section id="menu">

  <h2><%= restaurant.sections.featuredTitle %></h2>

  <div class="grid">

    <% restaurant.featuredDishes.forEach(dish => { %>

      <div class="card">
        <img src="<%= dish.image %>" alt="<%= dish.name %>">

        <h3><%= dish.name %></h3>
        <p><%= dish.description %></p>
        <span><%= dish.price %></span>

        <a href="<%= restaurant.links.whatsappBase %>?text=<%= encodeURIComponent(restaurant.messages.orderDishPrefix + ' ' + dish.name) %>">
          <%= restaurant.buttons.order %>
        </a>
      </div>

    <% }) %>

  </div>

</section>

<section class="testimonials">

  <h2><%= restaurant.sections.testimonialsTitle %></h2>

  <% restaurant.testimonials.forEach(t => { %>
    <div class="testimonial">
      <strong><%= t.name %></strong>
      <p><%= t.comment %></p>
      <span><%= '★'.repeat(t.rating) %></span>
    </div>
  <% }) %>

</section>

<section class="cta">

  <h2><%= restaurant.cta.title %></h2>
  <p><%= restaurant.cta.text %></p>

  <a href="<%= restaurant.links.whatsappBase %>?text=<%= encodeURIComponent(restaurant.messages.whatsappGlobal) %>">
    <%= restaurant.buttons.whatsapp %>
  </a>

</section>

<footer>
  <p><%= restaurant.footer.copy %></p>
</footer>

</body>
<script src="/js/animations.js"></script>
</html>
